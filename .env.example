# FlowState Environment Variables
# --------------------------------
# This file is a template required for Phase 2 MongoDB Atlas integration.
# Do NOT commit the actual .env file with real secrets to version control.
# Copy this file to '.env' and fill in your MongoDB Atlas credentials.

# MongoDB Atlas Configuration (Planned for Phase 2)
MONGODB_URI=your_mongodb_atlas_connection_string_here
MONGODB_DB_NAME=flowstate

# --------------------------------
# If adding AI endpoints in Phase 3, add them below:
# OPENAI_API_KEY=your_openai_api_key_here
